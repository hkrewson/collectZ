{
  "version": 1,
  "strategy": "private-source-to-clean-public-mirror",
  "publicHistoryPolicy": "clean-commits-only",
  "publicMirror": {
    "defaultBranch": "main",
    "includeGitHistory": false,
    "publishFromLocalGate": true,
    "containerRegistry": "ghcr.io/hkrewson"
  },
  "allowedPathPrefixes": [
    "setup.sh",
    "README.md",
    "SECURITY.md",
    "docker-compose.yml",
    "env.example",
    "app-meta.json",
    "docs/public/",
    "public-mirror/",
    "backend/openapi/",
    "frontend/index.html",
    "frontend/package-lock.json",
    "frontend/package.json",
    "frontend/src/",
    "frontend/tailwind.config.js",
    "frontend/vite.config.js"
  ],
  "deniedPathPrefixes": [
    ".ci/",
    "artifacts/",
    "backend/artifacts/",
    "backend/backend/",
    "backend/.dockerignore",
    "backend/Dockerfile",
    "backend/app-meta.json",
    "backend/config/",
    "backend/db/",
    "backend/healthcheck.js",
    "backend/middleware/",
    "backend/package-lock.json",
    "backend/package.json",
    "backend/release-feed.json",
    "backend/routes/",
    "backend/scripts/",
    "backend/server.js",
    "backend/services/",
    "backend/test/",
    "backend/uploads/",
    "docs/wiki/",
    "ops/",
    "public-export/",
    "frontend/.dockerignore",
    "frontend/dist/",
    "frontend/Dockerfile",
    "frontend/nginx.conf",
    "frontend/public/",
    "tests/playwright/artifacts/",
    "playwright-report/",
    "test-results/",
    "node_modules/",
    "backend/node_modules/",
    "frontend/node_modules/"
  ],
  "deniedExactPaths": [
    ".env",
    ".env.local",
    ".env.production",
    "docker-compose.localhost.yml",
    "preflight-go-no-go.md"
  ],
  "deniedContentPatterns": [
    "APP_EDITION",
    "PLAYWRIGHT_E2E_BYPASS_TOKEN",
    "ALLOW_SESSION_BEARER_FALLBACK",
    "runtime-smoke",
    "control-plane",
    "docs/wiki",
    "support_admin",
    "server-admin",
    "homelab edition",
    "platform edition"
  ],
  "contentScanPathPrefixes": [
    "*"
  ],
  "mappedPathPrefixes": [
    {
      "source": "public-mirror/",
      "target": ""
    }
  ],
  "requiredPublicDocs": [
    "README.md",
    "SECURITY.md"
  ],
  "notes": [
    "The public mirror is generated from a private source-of-truth checkout after local validation, not by pushing or mirroring private git history.",
    "The first public mirror includes deployment files, public setup docs, audited frontend source, the public OpenAPI contract, and version metadata for the GHCR containers. Backend implementation source stays in the private source-of-truth repository.",
    "The allowlist defines the first export contract. A path must be intentionally allowed before it can appear in a generated public tree.",
    "The denylist wins over the allowlist."
  ]
}
