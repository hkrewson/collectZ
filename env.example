# Required secrets
# Generate strong values before startup:
#   openssl rand -hex 32
DB_PASSWORD=
SESSION_SECRET=
INTEGRATION_ENCRYPTION_KEY=

# Optional database names. Leave these defaults unless you are attaching
# collectZ to an existing database/user.
DB_USER=collectz
POSTGRES_DB=collectz
DATABASE_SSL=false

# Browser origins allowed to call the API.
# Add your public HTTPS origin when deploying behind a domain.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Public compose defaults NODE_ENV to production.
# For HTTPS/reverse-proxy deployment, keep secure cookies enabled.
# For direct HTTP-only local testing, set this to false.
SESSION_COOKIE_SECURE=true

# Reverse proxy trust (Express `trust proxy`):
# - set to 1 when running behind exactly one proxy hop (common docker/nginx setup)
# - set to false when accessing backend directly (no proxy)
TRUST_PROXY=1
