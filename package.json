{
  "name": "collectz-browser-tests",
  "private": true,
  "scripts": {
    "test:browser": "playwright test",
    "test:browser:capture": "playwright test tests/playwright/specs/support-docs.capture.spec.js",
    "test:browser:headed": "playwright test --headed",
    "test:browser:ui": "playwright test --ui",
    "compose:generate": "node scripts/generate-public-compose.js",
    "validate:public-export": "node scripts/validate-public-export-surface.js",
    "stack:up": "docker compose --env-file .env up -d",
    "stack:up:homelab": "docker compose --env-file .env up -d",
    "stack:up:platform": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.localhost.yml up -d --build",
    "stack:down": "docker compose --env-file .env down",
    "stack:down:homelab": "docker compose --env-file .env down",
    "stack:down:platform": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.localhost.yml down",
    "stack:ps": "docker compose --env-file .env ps",
    "stack:ps:homelab": "docker compose --env-file .env ps",
    "stack:ps:platform": "docker compose --env-file .env -f docker-compose.yml -f docker-compose.localhost.yml ps",
    "ops:sizing": "node ops/sizing/collectz-sizing-snapshot.js",
    "test:runtime-smoke:local": "docker compose --env-file .env exec -T -e BASE_URL=http://frontend:3000 backend npm run test:core-runtime-smoke && docker compose --env-file .env -f docker-compose.yml -f docker-compose.localhost.yml exec -T -e BASE_URL=http://frontend:3000 backend npm run test:control-plane-runtime-smoke",
    "test:edition-boundaries:local": "npm run test:runtime-smoke:local"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
